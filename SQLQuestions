Find 2nd Highest Salary
Using DENSE_RANK() (Recommended)

WITH SalaryCTE AS
(
    SELECT Salary,
           DENSE_RANK() OVER (ORDER BY Salary DESC) AS DR
    FROM Employee
)
SELECT DISTINCT Salary
FROM SalaryCTE
WHERE DR = 2;

Find Both 2nd and 3rd Highest Salary Together

WITH SalaryCTE AS
(
    SELECT Salary,
           DENSE_RANK() OVER (ORDER BY Salary DESC) AS DR
    FROM Employee
)
SELECT DISTINCT Salary, DR
FROM SalaryCTE
WHERE DR IN (2,3);

